<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="container">
  <h2 class="section-title">Connect With Us</h2>

  <div class="checkout-layout" style="margin-top: 60px;">
    <!-- Left Column: Contact Coordinates -->
    <div style="display: flex; flex-direction: column; gap: 40px;">
      <div>
        <h3 style="font-family: var(--font-display); font-size: 1.5rem; text-transform: uppercase; margin-bottom: 20px; letter-spacing: 0.05em;">
          The Paris Atelier
        </h3>
        <p style="font-size: 0.85rem; line-height: 1.8; color: var(--text-muted);">
          18 Rue du Faubourg Saint-Honoré<br>
          75008 Paris, France
        </p>
      </div>

      <div>
        <h3 style="font-family: var(--font-display); font-size: 1.5rem; text-transform: uppercase; margin-bottom: 20px; letter-spacing: 0.05em;">
          Inquiries & Appointments
        </h3>
        <p style="font-size: 0.85rem; line-height: 1.8; color: var(--text-muted);">
          General & Press: <strong>inquiries@maisonether.com</strong><br>
          Private fittings: <strong>ateliers@maisonether.com</strong><br>
          Telephone: <strong>+33 (0) 1 42 68 53 00</strong>
        </p>
      </div>

      <div style="background-color: rgba(0,0,0,0.02); padding: 25px; border-left: 2px solid var(--accent-color);">
        <h4 style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">
          Private Showings
        </h4>
        <p style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.6;">
          Our Paris atelier welcomes patrons by private invitation or pre-arranged consultation schedules only. To request a fitting session or view seasonal fabric selectors, please fill out the inquiry form.
        </p>
      </div>
    </div>

    <!-- Right Column: Submission Form -->
    <form class="form-section" action="/api/contact-submit" method="POST" onsubmit="alert('Inquiry successfully recorded. An artisan advisor will connect with you.'); this.reset(); return false;">
      <h3>Send an Inquiry</h3>
      
      <div class="form-grid full">
        <div class="input-wrap">
          <label for="contact-name">Your Full Name *</label>
          <input type="text" id="contact-name" name="name" required placeholder="e.g. Jean Constant">
        </div>
      </div>

      <div class="form-grid">
        <div class="input-wrap">
          <label for="contact-email">Email Address *</label>
          <input type="email" id="contact-email" name="email" required placeholder="e.g. constant@atelier.com">
        </div>
        <div class="input-wrap">
          <label for="contact-subject">Inquiry Subject *</label>
          <select id="contact-subject" name="subject" required>
            <option value="fitting">Private Fitting Appointment</option>
            <option value="order">Existing Order Status</option>
            <option value="custom">Bespoke Custom Fabric Selection</option>
            <option value="general">General Brand Question</option>
          </select>
        </div>
      </div>

      <div class="form-grid full">
        <div class="input-wrap">
          <label for="contact-message">Inquiry Details *</label>
          <textarea id="contact-message" name="message" rows="6" required placeholder="Describe your fitting, sizing, or styling requirements..."></textarea>
        </div>
      </div>

      <button type="submit" class="btn" style="width: 100%; padding: 20px 0;">
        Submit Inquiry
      </button>
    </form>
  </div>
</main>

<%- include('partials/footer') %>
