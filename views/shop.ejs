<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="container">
  <h2 class="section-title">La Galerie</h2>
  
  <div class="shop-layout">
    <!-- Filters Sidebar -->
    <aside class="filters-sidebar">
      <!-- Category Filter -->
      <div class="filter-group">
        <h4>Category</h4>
        <ul class="filter-options">
          <li>
            <label>
              <input type="checkbox" class="category-filter" value="dresses">
              Dresses
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="category-filter" value="outerwear">
              Outerwear
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="category-filter" value="knitwear">
              Knitwear
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="category-filter" value="trousers">
              Trousers
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="category-filter" value="tops">
              Tops
            </label>
          </li>
        </ul>
      </div>

      <!-- Size Filter -->
      <div class="filter-group">
        <h4>Size</h4>
        <ul class="filter-options">
          <li>
            <label>
              <input type="checkbox" class="size-filter" value="S">
              S
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="size-filter" value="M">
              M
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="size-filter" value="L">
              L
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="size-filter" value="XL">
              XL
            </label>
          </li>
        </ul>
      </div>

      <!-- Colors Filter -->
      <div class="filter-group">
        <h4>Colors</h4>
        <ul class="filter-options">
          <li>
            <label>
              <input type="checkbox" class="color-filter" value="noir">
              Noir / Charcoal-Black
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="color-filter" value="bone">
              Bone / Pearl White
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="color-filter" value="charcoal">
              Charcoal
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="color-filter" value="burgundy">
              Burgundy
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="color-filter" value="forest green">
              Forest Green
            </label>
          </li>
        </ul>
      </div>

      <!-- Price Range Filter -->
      <div class="filter-group">
        <h4>Price Range</h4>
        <div class="price-range-slider">
          <input type="range" id="price-slider" min="500" max="3000" step="100" value="3000" aria-label="Price range filter">
          <div class="price-range-labels">
            <span>₹500</span>
            <span id="price-slider-value">Max: ₹3,000</span>
          </div>
        </div>
      </div>

      <button id="clear-filters-btn" class="btn btn-secondary btn-small" style="width: 100%;">Clear Filters</button>
    </aside>

    <!-- Products Catalog Column -->
    <section>
      <!-- Sort & Count Header -->
      <div class="catalog-header">
        <div class="catalog-count" id="catalog-count-label">
          Showing <%= products.length %> garments
        </div>
        <div class="catalog-sort">
          <select id="sort-selector" aria-label="Sort products">
            <option value="latest">Sort: Latest Exhibition</option>
            <option value="price-asc">Price: Low to High</option>
            <option value="price-desc">Price: High to Low</option>
          </select>
        </div>
      </div>

      <!-- Products Grid -->
      <div class="product-grid" id="catalog-grid">
        <% if (products && products.length > 0) { %>
          <% products.forEach(product => { 
            // Compile sizing variants string for easy data extraction on client
            const sizeStr = product.variants.map(v => v.stock > 0 ? v.size : '').join(',').toLowerCase();
            const colorStr = product.colors.join(',').toLowerCase();
          %>
            <article class="product-card" 
                     data-id="<%= product.id %>"
                     data-category="<%= product.category.toLowerCase() %>" 
                     data-price="<%= product.price %>" 
                     data-colors="<%= colorStr %>" 
                     data-sizes="<%= sizeStr %>"
                     data-date="<%= product.created_at %>">
              <a href="/products/<%= product.slug %>" class="product-image-wrap" aria-label="View <%= product.name %>">
                <img src="<%= product.images[0] %>" alt="<%= product.name %>" loading="lazy">
              </a>
              <div class="product-info">
                <div class="product-details">
                  <a href="/products/<%= product.slug %>" class="product-name"><%= product.name %></a>
                  <span class="product-category"><%= product.category %></span>
                </div>
                <span class="product-price">₹<%= parseFloat(product.price).toLocaleString('en-IN') %></span>
              </div>
            </article>
          <% }) %>
        <% } else { %>
          <p style="grid-column: span 3; text-align: center; color: var(--text-muted);">No garments match this catalog selection.</p>
        <% } %>
      </div>
    </section>
  </div>
</main>

<!-- Client Side Catalog Filtering & Sorting script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.getElementById('catalog-grid');
    const cards = Array.from(grid.querySelectorAll('.product-card'));
    const countLabel = document.getElementById('catalog-count-label');
    const sortSelect = document.getElementById('sort-selector');
    const priceSlider = document.getElementById('price-slider');
    const priceSliderVal = document.getElementById('price-slider-value');
    const clearBtn = document.getElementById('clear-filters-btn');

    // Trigger filters on change
    document.querySelectorAll('.filters-sidebar input').forEach(input => {
      input.addEventListener('change', applyFilters);
    });

    if (priceSlider) {
      priceSlider.addEventListener('input', (e) => {
        priceSliderVal.textContent = `Max: ₹${parseInt(e.target.value).toLocaleString('en-IN')}`;
        applyFilters();
      });
    }

    if (sortSelect) {
      sortSelect.addEventListener('change', applySort);
    }

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        document.querySelectorAll('.filters-sidebar input[type="checkbox"]').forEach(cb => cb.checked = false);
        if (priceSlider) {
          priceSlider.value = 3000;
          priceSliderVal.textContent = 'Max: ₹3,000';
        }
        applyFilters();
      });
    }

    function applyFilters() {
      // 1. Get filter parameters
      const checkedCategories = Array.from(document.querySelectorAll('.category-filter:checked')).map(cb => cb.value);
      const checkedSizes = Array.from(document.querySelectorAll('.size-filter:checked')).map(cb => cb.value.toLowerCase());
      const checkedColors = Array.from(document.querySelectorAll('.color-filter:checked')).map(cb => cb.value.toLowerCase());
      const maxPrice = parseFloat(priceSlider ? priceSlider.value : 3000);

      let visibleCount = 0;

      cards.forEach(card => {
        const cat = card.getAttribute('data-category');
        const price = parseFloat(card.getAttribute('data-price'));
        const colors = card.getAttribute('data-colors');
        const sizes = card.getAttribute('data-sizes');

        // Check conditions
        const catMatch = checkedCategories.length === 0 || checkedCategories.includes(cat);
        const priceMatch = price <= maxPrice;
        
        // Colors match if any checked color is present in colors string
        const colorMatch = checkedColors.length === 0 || checkedColors.some(c => colors.includes(c));
        
        // Sizes match if any checked size is present in sizes string
        const sizeMatch = checkedSizes.length === 0 || checkedSizes.some(s => sizes.includes(s));

        if (catMatch && priceMatch && colorMatch && sizeMatch) {
          card.style.display = 'flex';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (countLabel) {
        countLabel.textContent = `Showing ${visibleCount} garments`;
      }
    }

    function applySort() {
      const criteria = sortSelect.value;
      const sortedCards = [...cards];

      sortedCards.sort((a, b) => {
        const priceA = parseFloat(a.getAttribute('data-price'));
        const priceB = parseFloat(b.getAttribute('data-price'));
        const dateA = new Date(a.getAttribute('data-date'));
        const dateB = new Date(b.getAttribute('data-date'));

        if (criteria === 'price-asc') {
          return priceA - priceB;
        } else if (criteria === 'price-desc') {
          return priceB - priceA;
        } else {
          // Default latest
          return dateB - dateA;
        }
      });

      // Clear grid and re-append sorted items
      grid.innerHTML = '';
      sortedCards.forEach(card => grid.appendChild(card));
    }
    
    // Read category from query parameters if pre-selected
    const urlParams = new URLSearchParams(window.location.search);
    const categoryParam = urlParams.get('category');
    if (categoryParam) {
      const checkbox = document.querySelector(`.category-filter[value="${categoryParam.toLowerCase()}"]`);
      if (checkbox) {
        checkbox.checked = true;
        applyFilters();
      }
    }
  });
</script>

<%- include('partials/footer') %>
