<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Prevent theme flicker by applying theme class before CSS parses -->
  <script>
    (function() {
      const theme = localStorage.getItem('thistlewood_theme') || 'daylight';
      if (theme === 'evening') {
        document.documentElement.classList.add('theme-evening');
      } else {
        document.documentElement.classList.remove('theme-evening');
      }
    })();
  </script>

  <!-- SVG Favicon with compact icon-only thistle mark -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22 fill=%22%2323241F%22><path fill-rule=%22evenodd%22 d=%22M50 88 L63 75 L50 62 L37 75 Z M50 80 L43 73 L50 66 L57 73 Z M32 70 L45 57 L49 61 L36 74 Z M68 70 L55 57 L51 61 L64 74 Z M27 65 L40 52 L44 56 L31 69 Z M73 65 L60 52 L56 56 L69 69 Z M47.5 48 L47.5 15 L52.5 15 L52.5 48 Z M39 48 L32 18 L37 18 L44 48 Z M61 48 L68 18 L63 18 L56 48 Z M30.5 48 L12 24 L17 24 L35.5 48 Z M69.5 48 L88 24 L83 24 L64.5 48 Z%22 /></svg>">
  
  <!-- Dynamic SEO Metadata -->
  <title><%= typeof title !== 'undefined' ? title : 'Thistlewood | English Tailoring & Heritage Garments' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Thistlewood is a British luxury clothing brand dedicated to modernized English tailoring, premium woolen fabrics, and structured silhouettes.' %>">
  
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Thistlewood | English Tailoring & Heritage Garments' %>">
  <meta property="og:description" content="<%= typeof description !== 'undefined' ? description : 'Artisanal British tailoring and wool coats.' %>">
  <meta property="og:type" content="website">
  
  <!-- Fonts & Core Stylesheets -->
  <link rel="stylesheet" href="/css/style.css">
  
  <!-- Render Schema.org Product Structured Data if provided -->
  <% if (typeof structuredData !== 'undefined' && structuredData) { %>
    <script type="application/ld+json">
      <%- JSON.stringify(structuredData) %>
    </script>
  <% } %>
</head>
