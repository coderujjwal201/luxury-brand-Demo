<body>
  <!-- Upper Header vignette layer for Option B -->
  <div class="vignette-layer"></div>

  <header>
    <div class="header-container">
      <!-- Logo Horizontal Lockup -->
      <a href="/" class="logo" aria-label="Thistlewood Home" style="display: flex; align-items: center; gap: 14px; color: var(--text-color);">
        <svg class="logo-svg" viewBox="0 0 100 100" width="30" height="30" fill="currentColor" style="display: inline-block; vertical-align: middle;">
          <!-- Geometric thistle icon matching brand specifications -->
          <path fill-rule="evenodd" d="M50 88 L63 75 L50 62 L37 75 Z M50 80 L43 73 L50 66 L57 73 Z M32 70 L45 57 L49 61 L36 74 Z M68 70 L55 57 L51 61 L64 74 Z M27 65 L40 52 L44 56 L31 69 Z M73 65 L60 52 L56 56 L69 69 Z M47.5 48 L47.5 15 L52.5 15 L52.5 48 Z M39 48 L32 18 L37 18 L44 48 Z M61 48 L68 18 L63 18 L56 48 Z M30.5 48 L12 24 L17 24 L35.5 48 Z M69.5 48 L88 24 L83 24 L64.5 48 Z" />
        </svg>
        <span style="font-family: var(--font-display); font-size: 1.35rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;">Thistlewood</span>
      </a>
      
      <!-- Desktop Navigation Menu -->
      <nav>
        <ul class="nav-links">
          <li><a href="/shop">Shop</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href="/faq">FAQ</a></li>
        </ul>
      </nav>
      
      <!-- Interactive Options -->
      <div class="header-actions">
        <!-- Theme Toggle Switch -->
        <div class="theme-switch-container">
          <span class="switch-label">Light</span>
          <button id="theme-toggle" class="theme-toggle-btn" aria-label="Toggle brand styling theme">
            <span class="theme-toggle-knob"></span>
          </button>
          <span class="switch-label">Dark</span>
        </div>
        
        <!-- Shopping Cart Icon Link -->
        <a href="/cart" class="cart-icon" aria-label="Shopping Bag">
          Bag
          <span class="cart-count">0</span>
        </a>
        
        <!-- Mobile Menu Trigger -->
        <button class="mobile-nav-toggle" aria-label="Open navigation drawer">&#9776;</button>
      </div>
    </div>
  </header>
