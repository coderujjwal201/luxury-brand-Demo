<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="container" id="cart-page-container">
  <h2 class="section-title">Your Bag</h2>

  <!-- Empty State -->
  <div id="cart-empty-state" class="centered-message" style="display: none;">
    <h2>Your shopping bag is empty</h2>
    <p>We invite you to browse our collections and discover garments tailored to last a lifetime.</p>
    <a href="/shop" class="btn">Explore All Garments</a>
  </div>

  <!-- Cart Content Layout -->
  <div class="cart-layout" id="cart-table-wrapper" style="display: none;">
    <!-- Items table columns -->
    <div style="overflow-x: auto;">
      <table class="cart-table">
        <thead>
          <tr>
            <th>Garment Details</th>
            <th>Quantity</th>
            <th>Total Price</th>
          </tr>
        </thead>
        <tbody id="cart-items-tbody">
          <!-- Dynamic entries generated by cart.js -->
        </tbody>
      </table>
    </div>

    <!-- Pricing summaries side column -->
    <aside class="cart-summary-panel">
      <h3>Order Summary</h3>
      
      <div class="summary-row">
        <span>Subtotal</span>
        <span id="cart-subtotal-amount">₹0.00</span>
      </div>
      
      <div class="summary-row">
        <span>Delivery Surcharges</span>
        <span style="color: var(--accent-color); font-weight: 500;">Complimentary</span>
      </div>

      <!-- Promo Code Section -->
      <div style="margin: 10px 0;">
        <p style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 8px;">Promotional Code</p>
        <div class="promo-form">
          <input type="text" id="promo-input" placeholder="e.g. COUTURE10" aria-label="Promo code input">
          <button type="button" id="apply-promo-btn">Apply</button>
        </div>
        <p id="promo-status-msg" style="font-size: 0.7rem; margin-top: 5px; text-transform: uppercase; font-weight: 500; letter-spacing: 0.05em; display: none;"></p>
      </div>

      <div class="summary-row total">
        <span>Total (GST Inc.)</span>
        <span id="cart-total-amount">₹0.00</span>
      </div>

      <a href="/checkout" class="btn" style="text-align: center; display: block; margin-top: 15px;">
        Proceed to Checkout
      </a>
      
      <p style="font-size: 0.65rem; color: var(--text-muted); text-align: center; line-height: 1.5; margin-top: 10px;">
        Taxes and customs duties are calculated at checkout. Returns are accepted within 14 days.
      </p>
    </aside>
  </div>
</main>

<script>
  // Simple promo discount hook
  document.addEventListener('DOMContentLoaded', () => {
    const promoBtn = document.getElementById('apply-promo-btn');
    const promoInput = document.getElementById('promo-input');
    const statusMsg = document.getElementById('promo-status-msg');
    
    if (promoBtn && promoInput) {
      promoBtn.addEventListener('click', () => {
        const code = promoInput.value.trim().toUpperCase();
        if (code === 'COUTURE10') {
          // Calculate discount in cart.js
          applyDiscount(10);
        } else if (code === 'ARCHIVE20') {
          applyDiscount(20);
        } else {
          statusMsg.style.display = 'block';
          statusMsg.style.color = '#EF4444';
          statusMsg.textContent = 'Invalid promotional code';
        }
      });
    }

    function applyDiscount(percent) {
      // Find subtotal
      const subtotalLabel = document.getElementById('cart-subtotal-amount');
      const totalLabel = document.getElementById('cart-total-amount');
      
      if (!subtotalLabel || !totalLabel) return;
      
      // Calculate
      let subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
      let discount = subtotal * (percent / 100);
      let newTotal = subtotal - discount;

      totalLabel.textContent = `₹${newTotal.toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;
      
      statusMsg.style.display = 'block';
      statusMsg.style.color = 'var(--accent-color)';
      statusMsg.textContent = `Promo Code Applied: ${percent}% off order subtotal`;
      
      // Save discount percent in sessionStorage for checkout retrieval
      sessionStorage.setItem('thistlewood_discount', percent);
    }
  });
</script>

<%- include('partials/footer') %>
